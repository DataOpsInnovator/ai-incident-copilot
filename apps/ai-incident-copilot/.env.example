# Copy this file to `.env` and edit values to match your local setup.
# `.env` itself is gitignored — never commit secrets.

# Oracle AI Database 26ai
# Application user is created by scripts/setup_db.sh — DO NOT use SYSTEM
# (VECTOR columns are not allowed in the SYSTEM tablespace).
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_USER=copilot
ORACLE_PASSWORD=Welcome_123

# Ollama (local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
